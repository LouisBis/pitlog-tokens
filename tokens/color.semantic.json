{
  "background": {
    "base":     { "$value": "{color.slate.900}", "$type": "color" },
    "surface":  { "$value": "{color.slate.800}", "$type": "color" },
    "elevated": { "$value": "{color.slate.750}", "$type": "color" }
  },
  "border": {
    "default": { "$value": "{color.slate.700}", "$type": "color" },
    "subtle":  { "$value": "{color.slate.800}", "$type": "color" }
  },
  "text": {
    "primary":   { "$value": "{color.slate.100}", "$type": "color" },
    "secondary": { "$value": "{color.slate.400}", "$type": "color" },
    "muted":     { "$value": "{color.slate.600}", "$type": "color" }
  },
  "accent": {
    "default": { "$value": "{color.orange.500}", "$type": "color" },
    "subtle":  { "$value": "rgba(249, 115, 22, 0.12)", "$type": "color" },
    "text":    { "$value": "{color.orange.400}", "$type": "color" }
  },
  "status": {
    "danger":  { "$value": "{color.red.500}",   "$type": "color" },
    "warning": { "$value": "{color.amber.500}", "$type": "color" },
    "success": { "$value": "{color.green.500}", "$type": "color" }
